{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationDir": "dist/types",
		"rootDir": "src",
		"noEmit": false,
		"composite": false
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"dist",
		"node_modules",
		"**/*.test.ts",
		"**/*.spec.ts"
	]
}
