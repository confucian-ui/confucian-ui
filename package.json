{
	"name": "confucian-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "Confucian — Vuetify v4 admin template with the gravitas of Confucian aesthetics.",
	"type": "module",
	"author": "Mu-Tsun Tsai <don.m.t.tsai@gmail.com> (https://github.com/MuTsunTsai)",
	"scripts": {
		"build": "pnpm --filter @confucian-ui/vuetify build && pnpm -r --filter=!@confucian-ui/vuetify build",
		"build:demo": "pnpm --filter confucian-demo build",
		"build:starter": "pnpm --filter confucian-starter build",
		"build:vuetify": "pnpm --filter @confucian-ui/vuetify build",
		"clean": "pnpm -r exec rm -rf dist node_modules",
		"dev": "pnpm -r --parallel dev",
		"dev:demo": "pnpm --filter confucian-demo dev",
		"dev:starter": "pnpm --filter confucian-starter dev",
		"typecheck": "pnpm -r typecheck"
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.0.0",
	"devDependencies": {
		"@mutsuntsai/eslint": "^1.4.5",
		"eslint": "^10.2.0",
		"typescript": "^6.0.2"
	}
}
